# Server URL (defaults to http://localhost:3000)
# MCP_URL=https://your-server.com

# ─── Event source providers ────────────────────────────────────────────────────
# Add API keys for the sources you want to activate.
# Providers without a key are silently skipped.

# Luma — no key required, always active

# Meetup — requires a Pro account ($29/mo) for keyword search across all events
# Get token: https://www.meetup.com/api/oauth/list
# MEETUP_ACCESS_TOKEN=

# Ticketmaster Discovery — free API key, instant registration
# Get key: https://developer.ticketmaster.com/products-and-docs/apis/getting-started/
# TICKETMASTER_API_KEY=

# LinkedIn Events — unofficial Voyager API, use your li_at session cookie
# Get cookie: log in to linkedin.com → DevTools → Application → Cookies → li_at
# ⚠️ Unofficial — may break without notice
# LINKEDIN_LI_AT=

# PredictHQ — AI-enriched event intelligence, free trial available
# Get token: https://www.predicthq.com/
# PREDICTHQ_TOKEN=
